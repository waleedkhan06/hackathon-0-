# AI Employee Gold Tier - Environment Configuration
# =====================================================
# IMPORTANT: This file contains sensitive credentials
# - NEVER commit this file to version control
# - Keep this file secure and private
# - Rotate credentials regularly

# =====================================================
# SYSTEM CONFIGURATION
# =====================================================

# Run in demo mode (no real API calls)
# Set to 'false' when you have configured real credentials
DEMO_MODE=true

# Audit log retention period (days)
AUDIT_RETENTION_DAYS=90

# Maximum Ralph Wiggum iterations
MAX_RALPH_ITERATIONS=10

# =====================================================
# GMAIL API CONFIGURATION
# =====================================================
# Required for Gmail Watcher and Email MCP Server
# Get credentials from: https://console.cloud.google.com/

# Gmail OAuth 2.0 Credentials
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here
GMAIL_TOKEN=

# Set to 'false' when credentials are configured
GMAIL_DEMO_MODE=true

# =====================================================
# LINKEDIN API CONFIGURATION
# =====================================================
# Required for LinkedIn Poster
# Get credentials from: https://www.linkedin.com/developers/

# LinkedIn OAuth 2.0 Credentials
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REDIRECT_URI=http://localhost:8080/callback

# Set to 'true' for demo mode (posts saved locally)
LINKEDIN_DEMO_MODE=true

# =====================================================
# WHATSAPP CONFIGURATION
# =====================================================
# Required for WhatsApp Watcher
# Note: Uses WhatsApp Web automation

# Enable WhatsApp monitoring
WHATSAPP_ENABLED=false

# Session storage path
WHATSAPP_SESSION_PATH=./sessions/whatsapp

# Keywords to monitor (comma-separated)
WHATSAPP_KEYWORDS=urgent,asap,invoice,payment,help,meeting,deadline

# =====================================================
# TWITTER (X) API CONFIGURATION - GOLD TIER
# =====================================================
# Required for Twitter Watcher and MCP Server
# Get credentials from: https://developer.twitter.com/

# Twitter API v2 Credentials (Elevated Access Required)
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Set to 'false' when credentials are configured
TWITTER_DEMO_MODE=true

# Twitter watcher interval (seconds)
TWITTER_WATCHER_INTERVAL=300

# =====================================================
# FACEBOOK CONFIGURATION - GOLD TIER (PLAYWRIGHT)
# =====================================================
# Uses Playwright browser automation (NO API KEYS NEEDED!)
# Similar to LinkedIn and WhatsApp approach

# Set to 'false' to enable Facebook posting via Playwright
FACEBOOK_DEMO_MODE=true

# Facebook session storage path
FACEBOOK_SESSION_PATH=./sessions/facebook

# Facebook watcher interval (seconds)
FACEBOOK_WATCHER_INTERVAL=600

# =====================================================
# INSTAGRAM CONFIGURATION - GOLD TIER (PLAYWRIGHT)
# =====================================================
# Uses Playwright browser automation (NO API KEYS NEEDED!)
# Similar to LinkedIn and WhatsApp approach

# Set to 'false' to enable Instagram posting via Playwright
INSTAGRAM_DEMO_MODE=true

# Instagram session storage path
INSTAGRAM_SESSION_PATH=./sessions/instagram

# Instagram watcher interval (seconds)
INSTAGRAM_WATCHER_INTERVAL=600

# =====================================================
# MCP SERVER CONFIGURATION
# =====================================================

# Email MCP Settings
EMAIL_MCP_ENABLED=true
EMAIL_MAX_SEND_PER_HOUR=10

# Browser MCP Settings (for web automation)
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# =====================================================
# SCHEDULER CONFIGURATION
# =====================================================

# Enable/disable scheduled tasks
SCHEDULER_ENABLED=true

# Timezone for scheduling
TIMEZONE=UTC

# Daily briefing time (24-hour format)
DAILY_BRIEFING_TIME=08:00

# End of day summary time
EOD_SUMMARY_TIME=18:00

# Weekly audit day and time (Gold Tier - CEO Briefing)
WEEKLY_AUDIT_DAY=sunday
WEEKLY_AUDIT_TIME=23:00

# Monday CEO briefing time (Gold Tier)
CEO_BRIEFING_DAY=monday
CEO_BRIEFING_TIME=07:00

# LinkedIn post day and time
LINKEDIN_POST_DAY=wednesday
LINKEDIN_POST_TIME=09:00

# Twitter post schedule (Gold Tier)
TWITTER_POST_DAYS=monday,wednesday,friday
TWITTER_POST_TIME=10:00

# Facebook post schedule (Gold Tier)
FACEBOOK_POST_DAYS=tuesday,thursday
FACEBOOK_POST_TIME=14:00

# Instagram post schedule (Gold Tier)
INSTAGRAM_POST_DAYS=monday,wednesday,friday
INSTAGRAM_POST_TIME=15:00

# Friday report time
FRIDAY_REPORT_TIME=16:00

# =====================================================
# LOGGING CONFIGURATION
# =====================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable audit logging
AUDIT_LOGGING_ENABLED=true

# Log file max size (MB)
LOG_MAX_SIZE=10

# Number of log files to retain
LOG_BACKUP_COUNT=7

# =====================================================
# SECURITY SETTINGS
# =====================================================

# Enable human-in-the-loop for sensitive actions
HITL_ENABLED=true

# Payment approval threshold (Silver tier: all payments need approval)
PAYMENT_APPROVAL_THRESHOLD=0

# Enable approval expiration (hours)
APPROVAL_EXPIRY_HOURS=24

# =====================================================
# ADVANCED SETTINGS
# =====================================================

# Claude Code command (if not in PATH, specify full path)
CLAUDE_COMMAND=claude

# Orchestrator check interval (seconds)
ORCHESTRATOR_INTERVAL=10

# Watcher check intervals (seconds)
FILE_WATCHER_INTERVAL=10
GMAIL_WATCHER_INTERVAL=120
WHATSAPP_WATCHER_INTERVAL=60

# =====================================================
# DEVELOPMENT SETTINGS
# =====================================================

# Enable debug mode
DEBUG=false

# Enable verbose logging
VERBOSE=false

# Skip SSL verification (development only!)
SKIP_SSL_VERIFY=false
