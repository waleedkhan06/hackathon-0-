# ===========================================
# PLATINUM TIER AI EMPLOYEE - .gitignore
# SECURITY CRITICAL: Secrets NEVER sync to Git
# ===========================================

# ===========================================
# ENVIRONMENT FILES (NEVER SYNC)
# ===========================================
.env
.env.*
!.env.example
*.env

# ===========================================
# CREDENTIALS & TOKENS (NEVER SYNC)
# ===========================================
*.token
*.session
*.key
*.secret
*.pem
*.crt
credentials/
secrets/
secure/

# ===========================================
# SESSION FOLDERS (NEVER SYNC)
# ===========================================
sessions/
whatsapp_session/
browser_session/
playwright-session/

# ===========================================
# PYTHON
# ===========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ===========================================
# VIRTUAL ENVIRONMENTS (NEVER SYNC)
# ===========================================
venv/
ENV/
env/
.venv/

# ===========================================
# IDE & EDITORS
# ===========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ===========================================
# LOGS (NEVER SYNC - MAY CONTAIN SENSITIVE DATA)
# ===========================================
logs/
*.log

# ===========================================
# TEMPORARY FILES
# ===========================================
tmp/
temp/
*.tmp
*.bak

# ===========================================
# SYNC FOLDERS (SYNC STRUCTURE ONLY)
# ===========================================
updates/*
!updates/.gitkeep
signals/*
!signals/.gitkeep
in_progress/*
!in_progress/.gitkeep

# ===========================================
# DATA FOLDERS (KEEP STRUCTURE, NOT CONTENT)
# ===========================================
done/*
!done/.gitkeep
approved/*
!approved/.gitkeep
pending_approval/*
!pending_approval/.gitkeep
rejected/*
!rejected/.gitkeep
needs_action/*
!needs_action/.gitkeep
plans/*
!plans/.gitkeep
drafts/*
!drafts/.gitkeep
inbox/*
!inbox/.gitkeep
briefings/*
!briefings/.gitkeep
archive/*
!archive/.gitkeep
